# Nginx configuration example for SPW-Transform microservice
# Place in your server block or include in site config

# If running as subdomain: api.smartpropertywidget.com
server {
    listen 80;
    listen 443 ssl http2;
    server_name api.smartpropertywidget.com;

    root /var/www/spw-transform;
    index index.php;

    # SSL configuration (adjust paths)
    ssl_certificate /etc/letsencrypt/live/api.smartpropertywidget.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.smartpropertywidget.com/privkey.pem;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # CORS headers
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With" always;

    # Handle preflight requests
    if ($request_method = 'OPTIONS') {
        return 204;
    }

    # Deny access to sensitive directories
    location ~ ^/(cache|config|src)/ {
        deny all;
        return 404;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        return 404;
    }

    # Route all requests to index.php
    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }

    # PHP processing
    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;

        # Pass environment variables
        fastcgi_param LARAVEL_URL "https://sm.smartpropertywidget.com";
        fastcgi_param INTERNAL_API_KEY "your-internal-api-key-here";
    }
}
